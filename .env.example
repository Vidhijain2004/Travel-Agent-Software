# Environment configuration for travel-scraper-playwright
# Copy this file to .env and adjust values

# Runner options
HEADLESS=true
RUN_IN_PARALLEL=true

# Flight search defaults
FLIGHT_FROM=DEL
FLIGHT_TO=BOM
# ISO 8601 date (YYYY-MM-DD)
FLIGHT_DEPART_DATE=2025-09-01

# Hotel search defaults
HOTEL_LOCATION=Mumbai
HOTEL_CHECKIN=2025-09-01
HOTEL_CHECKOUT=2025-09-03